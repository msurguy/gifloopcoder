{
  "name": "playground",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "predev": "npm run build:sandbox",
    "dev": "vite",
    "build": "npm run build:sandbox && vite build && cp dist/index.html dist/404.html",
    "build:sandbox": "vite build --config vite.sandbox.config.ts",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "e2e": "playwright test"
  },
  "dependencies": {
    "@astryxdesign/core": "0.1.2",
    "@astryxdesign/theme-neutral": "0.1.2",
    "@codemirror/autocomplete": "^6.20.3",
    "@codemirror/commands": "^6.10.4",
    "@codemirror/lang-javascript": "6.2.5",
    "@codemirror/state": "^6.7.0",
    "@codemirror/view": "^6.43.4",
    "codemirror": "6.0.2",
    "gifloopcoder": "*",
    "lz-string": "1.5.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "zustand": "5.0.14"
  },
  "devDependencies": {
    "@astryxdesign/cli": "0.1.2",
    "@playwright/test": "^1.61.0",
    "@types/node": "^26.1.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^6.0.0",
    "typescript": "^5.7.0",
    "vite": "^8.1.0"
  }
}
